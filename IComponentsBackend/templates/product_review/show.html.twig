{% extends 'base.html.twig' %}

{% block title %}ProductReview{% endblock %}

{% block body %}
    <h1>ProductReview</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ product_review.id }}</td>
            </tr>
            <tr>
                <th>Rating</th>
                <td>{{ product_review.rating }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ product_review.title }}</td>
            </tr>
            <tr>
                <th>Comment</th>
                <td>{{ product_review.comment }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ product_review.createdAt ? product_review.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_product_review_index') }}">back to list</a>

    <a href="{{ path('app_product_review_edit', {'id': product_review.id}) }}">edit</a>

    {{ include('product_review/_delete_form.html.twig') }}
{% endblock %}
